# ══════════════════════════════════════════════════
# NextFlow Environment Variables
# Copy this file to .env.local and fill in your keys
# ══════════════════════════════════════════════════

# ── Clerk Authentication ──────────────────────────
# Get from: https://clerk.com → Create Application
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_REPLACE_ME
CLERK_SECRET_KEY=sk_test_REPLACE_ME
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/workflow
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/workflow

# ── PostgreSQL via Neon ───────────────────────────
# Get from: https://neon.tech → Create project → Connection string
DATABASE_URL="postgresql:"

# ── Google Gemini API ─────────────────────────────
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIza_REPLACE_ME

# ── Trigger.dev ───────────────────────────────────
# Get from: https://trigger.dev → Project Settings → API Keys
TRIGGER_SECRET_KEY=tr_dev_REPLACE_ME
NEXT_PUBLIC_TRIGGER_PUBLIC_API_KEY=pk_dev_REPLACE_ME

# ── Transloadit ───────────────────────────────────
# Get from: https://transloadit.com → Account → API Keys
NEXT_PUBLIC_TRANSLOADIT_KEY=REPLACE_ME
TRANSLOADIT_SECRET=REPLACE_ME
# Transloadit template IDs (create in dashboard)
NEXT_PUBLIC_TRANSLOADIT_IMAGE_TEMPLATE_ID=REPLACE_ME
NEXT_PUBLIC_TRANSLOADIT_VIDEO_TEMPLATE_ID=REPLACE_ME

# ── App URL ───────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
